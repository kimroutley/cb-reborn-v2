{
  "name": "cb-reborn-functions",
  "description": "Club Blackout Reborn - Cloud Functions for push notifications",
  "main": "index.js",
  "scripts": {
    "test:rules": "firebase emulators:exec --only firestore \"node --test tests/firestore.rules.test.js\"",
    "test:cleanup": "node --test tests/cleanup_stale_games.test.js",
    "test:push": "node --test tests/detect_pushable_events.test.js",
    "test": "node --test tests/cleanup_stale_games.test.js tests/detect_pushable_events.test.js"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1"
  },
  "private": true
}
